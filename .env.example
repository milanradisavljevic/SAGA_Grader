# ──────────────────────────────────────────────
# SAGA – Environment Configuration
# ──────────────────────────────────────────────
# Kopiere diese Datei nach .env und fülle die
# Keys für deinen gewünschten LLM-Provider aus.
#
#   cp .env.example .env
# ──────────────────────────────────────────────

# Umgebung
SAGA_ENVIRONMENT=development
SAGA_LOG_LEVEL=INFO
SAGA_TIMEZONE=Europe/Berlin

# ─── LLM-Provider ─────────────────────────────
# Wähle einen Provider: anthropic | openai | glm | kimi | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120

# Anthropic (für Provider: anthropic)
# Hol dir einen Key unter: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (für Provider: openai)
# Hol dir einen Key unter: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# GLM / ZhipuAI (für Provider: glm)
# GLM_API_KEY=...
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Kimi / Moonshot (für Provider: kimi)
# KIMI_API_KEY=sk-...
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# Ollama (für Provider: ollama – lokal, kein API-Key nötig)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Sprache
DEFAULT_LANGUAGE=de
